AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_example
COGNITO_APP_CLIENT_ID=exampleclientid
COGNITO_REGION=us-east-1

# Preferred for Railway (direct credentials)
NETSUITE_CLIENT=your_consumer_key
NETSUITE_SECRET=your_consumer_secret
NETSUITE_TOKEN_ID=your_token_id
NETSUITE_TOKEN_SECRET=your_token_secret
NETSUITE_REALM=your_realm

# Optional legacy AWS mode (single JSON in Secrets Manager)
# NETSUITE_SECRET_NAME=netsuite/dashboard/oauth

NETSUITE_QUERY_PAGE_SIZE=1000
NETSUITE_DDB_CACHE_ENABLED=false
# Example table name: quai-dashboard-cache
NETSUITE_DDB_CACHE_TABLE=
NETSUITE_QUERY_CACHE_TTL_SECONDS=1800
NETSUITE_DDB_CACHE_MAX_PAYLOAD_BYTES=350000
